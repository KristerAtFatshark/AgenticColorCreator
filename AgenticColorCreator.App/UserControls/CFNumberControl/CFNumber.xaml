<UserControl x:Class="AgenticColorCreator.App.UserControls.CFNumberControl.CFNumber"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:textControls="clr-namespace:AgenticColorCreator.App.UserControls.CFTextBoxControl"
			 mc:Ignorable="d"
			 Height="24"
			 Margin="0,2,0,2"
			 d:DesignHeight="24"
			 d:DesignWidth="120">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="22" />
		</Grid.ColumnDefinitions>

		<textControls:CFTextBox x:Name="ValueTextBox"
						 Grid.Column="0"
						 Height="24"
						 ValidationMode="NumberOnly"
						 Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=TextValue, Mode=TwoWay}" />

		<Grid Grid.Column="1"
			  Height="24">
			<Grid.RowDefinitions>
				<RowDefinition Height="12" />
				<RowDefinition Height="12" />
			</Grid.RowDefinitions>

			<Button Grid.Row="0"
					Style="{StaticResource CF.NumberSpinnerButton}"
					Height="12"
					Padding="0"
					Click="OnIncreaseClick"
					Content="▲" />

			<Button Grid.Row="1"
					Style="{StaticResource CF.NumberSpinnerButton}"
					Height="12"
					Padding="0"
					Click="OnDecreaseClick"
					Content="▼" />
		</Grid>
	</Grid>
</UserControl>
