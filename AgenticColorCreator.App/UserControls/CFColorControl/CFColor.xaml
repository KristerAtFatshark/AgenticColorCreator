<UserControl x:Class="AgenticColorCreator.App.UserControls.CFColorControl.CFColor"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 d:DesignHeight="28"
			 d:DesignWidth="180">
	<Button x:Name="OpenPickerButton"
			Style="{StaticResource CF.Button}"
			Padding="6,4"
			Click="OpenPickerButton_Click">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="36" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Border x:Name="CheckerBorder"
					Grid.Column="0"
					Height="20"
					CornerRadius="3"
					BorderBrush="{StaticResource CF.Border.Default.Border}"
					BorderThickness="1"
					Background="Transparent">
				<Border x:Name="ColorOverlayBorder"
						Background="Transparent"
						CornerRadius="2" />
			</Border>

			<TextBlock x:Name="HexTextBlock"
					   Grid.Column="1"
					   Margin="10,0,0,0"
					   VerticalAlignment="Center"
					   Foreground="{StaticResource CF.Text.Default.Foreground}"
					   Text="" />
		</Grid>
	</Button>
</UserControl>
