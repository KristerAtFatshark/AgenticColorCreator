<UserControl x:Class="AgenticColorCreator.App.UserControls.CFTreeViewControl.CFTreeView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:local="clr-namespace:AgenticColorCreator.App.UserControls.CFTreeViewControl"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 mc:Ignorable="d"
			 d:DesignHeight="220"
			 d:DesignWidth="260">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
	</UserControl.Resources>
	<Grid>
		<TreeView x:Name="PreviewTreeView"
			  Style="{StaticResource CF.TreeViewStyle}"
			  ItemContainerStyle="{StaticResource CF.TreeViewItem}"
			  SelectedItemChanged="OnSelectedItemChanged"
			  PreviewMouseLeftButtonDown="OnPreviewTreeViewMouseLeftButtonDown"
			  LostFocus="PreviewTreeView_LostFocus"
			  />
		<Border Background="#80AAAAAA"
				 Visibility="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsMixedState, Converter={StaticResource BooleanToVisibilityConverter}}"
				 VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
			<TextBlock Text="– Mixed –"
					Foreground="Black" FontWeight="Bold"
					Opacity="0.8" FontSize="12"
					HorizontalAlignment="Center" VerticalAlignment="Center"
					TextWrapping="NoWrap"/>
		</Border>
	</Grid>
</UserControl>
