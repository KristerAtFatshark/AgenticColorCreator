<UserControl x:Class="AgenticColorCreator.App.UserControls.CFTextBoxControl.CFTextBox"
         xmlns:local="clr-namespace:AgenticColorCreator.App.UserControls.CFTextBoxControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 d:DesignHeight="24"
			 d:DesignWidth="160">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<local:TextBoxGrayIfMixedConverter x:Key="TextBoxGrayIfMixedConverter" />
			<local:MixedVisualVisibilityConverter x:Key="MixedVisualVisibilityConverter" />
</UserControl.Resources>
<Grid>
	<TextBox x:Name="InnerTextBox"
			 Style="{StaticResource CF.TextBox}"
			 Margin="0"
			 Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DisplayedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
			 Foreground="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsMixedState, Converter={StaticResource TextBoxGrayIfMixedConverter}}"
		/>
	<TextBlock Text="– Mixed –"
		Foreground="Gray"
		FontStyle="Italic"
		IsHitTestVisible="False"
		VerticalAlignment="Center"
		Margin="5,0,0,0">
		<TextBlock.Visibility>
			<MultiBinding Converter="{StaticResource MixedVisualVisibilityConverter}">
				<Binding Path="IsMixedState" RelativeSource="{RelativeSource AncestorType=UserControl}" />
				<Binding Path="IsEditing" RelativeSource="{RelativeSource AncestorType=UserControl}" />
			</MultiBinding>
		</TextBlock.Visibility>
	</TextBlock>
	</Grid>
</UserControl>
