<Window x:Class="AgenticColorCreator.App.Dialogs.ColorPickerWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Pick Color"
		Width="420"
		Height="440"
		WindowStartupLocation="CenterOwner"
		ResizeMode="NoResize"
		ShowInTaskbar="False">
	<Grid Margin="18">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock FontSize="18"
				   FontWeight="SemiBold"
				   Foreground="{StaticResource HeaderBrush}"
				   Text="Interactive Color Picker" />

		<Border Grid.Row="1"
				Margin="0,14,0,14"
				Height="92"
				CornerRadius="8"
				BorderBrush="#80FFFFFF"
				BorderThickness="1"
				Background="{Binding PreviewBrush}" />

		<Grid Grid.Row="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="22" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="56" />
			</Grid.ColumnDefinitions>

			<TextBlock VerticalAlignment="Center" Text="A" />
			<Slider Grid.Column="1"
					Minimum="0"
					Maximum="255"
					Value="{Binding Alpha, UpdateSourceTrigger=PropertyChanged}" />
			<TextBox Grid.Column="2"
					 Margin="10,0,0,0"
					 Text="{Binding AlphaText, UpdateSourceTrigger=PropertyChanged}" />

			<TextBlock Grid.Row="1" VerticalAlignment="Center" Text="R" />
			<Slider Grid.Row="1"
					Grid.Column="1"
					Minimum="0"
					Maximum="255"
					Value="{Binding Red, UpdateSourceTrigger=PropertyChanged}" />
			<TextBox Grid.Row="1"
					 Grid.Column="2"
					 Margin="10,0,0,0"
					 Text="{Binding RedText, UpdateSourceTrigger=PropertyChanged}" />

			<TextBlock Grid.Row="2" VerticalAlignment="Center" Text="G" />
			<Slider Grid.Row="2"
					Grid.Column="1"
					Minimum="0"
					Maximum="255"
					Value="{Binding Green, UpdateSourceTrigger=PropertyChanged}" />
			<TextBox Grid.Row="2"
					 Grid.Column="2"
					 Margin="10,0,0,0"
					 Text="{Binding GreenText, UpdateSourceTrigger=PropertyChanged}" />

			<TextBlock Grid.Row="3" VerticalAlignment="Center" Text="B" />
			<Slider Grid.Row="3"
					Grid.Column="1"
					Minimum="0"
					Maximum="255"
					Value="{Binding Blue, UpdateSourceTrigger=PropertyChanged}" />
			<TextBox Grid.Row="3"
					 Grid.Column="2"
					 Margin="10,0,0,0"
					 Text="{Binding BlueText, UpdateSourceTrigger=PropertyChanged}" />

			<TextBlock Grid.Row="4"
					   Margin="0,14,0,0"
					   VerticalAlignment="Center"
					   FontWeight="SemiBold"
					   Text="Hex" />
			<TextBox Grid.Row="4"
					 Grid.Column="1"
					 Grid.ColumnSpan="2"
					 Margin="0,14,0,0"
					 Text="{Binding HexValue, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<StackPanel Grid.Row="3"
					Margin="0,18,0,0"
					Orientation="Horizontal"
					HorizontalAlignment="Right">
			<Button MinWidth="80" IsDefault="True" Click="OkButton_Click" Content="OK" />
			<Button MinWidth="80" IsCancel="True" Click="CancelButton_Click" Content="Cancel" />
		</StackPanel>
	</Grid>
</Window>
