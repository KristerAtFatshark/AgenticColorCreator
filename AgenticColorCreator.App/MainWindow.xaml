<Window x:Class="AgenticColorCreator.App.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:userControls="clr-namespace:AgenticColorCreator.App.UserControls"
		xmlns:viewModels="clr-namespace:AgenticColorCreator.App.ViewModels"
		mc:Ignorable="d"
		Title="Agentic Color Creator"
		Background="{StaticResource Window.Default.Background}"
		Height="900"
		Width="1280"
		MinHeight="720"
		MinWidth="980">
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

		<DataTemplate DataType="{x:Type viewModels:StateGroupViewModel}">
			<StackPanel Margin="0,0,0,10">
				<Grid Margin="0,0,0,6">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock VerticalAlignment="Center"
							   FontWeight="SemiBold"
						   Foreground="{StaticResource Text.Default.Foreground}"
							   Text="{Binding DisplayName}" />
					<Button Grid.Column="1"
							Margin="0"
							Padding="8,2"
							Command="{Binding AddColorCommand}"
							Content="Add" />
				</Grid>

				<ItemsControl ItemsSource="{Binding Colors}" />
			</StackPanel>
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:ColorItemViewModel}">
			<Border Margin="0,0,0,12"
					Background="{StaticResource Panel.Default.Background}"
					BorderBrush="{StaticResource Border.Default.Border}"
					BorderThickness="1"
					CornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<Button Grid.Row="0"
							 Grid.Column="0"
							Width="44"
							Height="26"
							Margin="0,0,8,6"
							Padding="0"
							Background="{Binding PreviewBrush}"
							BorderBrush="{StaticResource Preview.Default.Border}"
							Command="{Binding OpenColorPickerCommand}">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="1"
										CornerRadius="5" />
							</ControlTemplate>
						</Button.Template>
					</Button>

					<TextBox Grid.Row="0"
							 Grid.Column="1"
							 Margin="0,0,8,6"
							 Padding="5,4"
							 VerticalContentAlignment="Center"
							 Text="{Binding HexValue, UpdateSourceTrigger=PropertyChanged}" />

					<TextBox Grid.Row="0"
							 Grid.Column="2"
							 Margin="0,0,8,6"
							 VerticalContentAlignment="Center"
							 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

					<ComboBox Grid.Row="0"
							  Grid.Column="3"
							  Width="92"
							  Margin="0,0,8,6"
					  Template="{StaticResource ComboBoxTemplate}"
							  VerticalContentAlignment="Center"
							  ItemContainerStyle="{StaticResource ComboPopupItemStyle}"
							  ItemsSource="{Binding AvailableStates}"
							  SelectedItem="{Binding State, UpdateSourceTrigger=PropertyChanged}">
						<ComboBox.Resources>
							<SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF4C4C4C" />
							<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#8BFF9600" />
							<SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF4C4C4C" />
							<SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF4C4C4C" />
							<SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFC8C8C8" />
							<SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFC8C8C8" />
						</ComboBox.Resources>
					</ComboBox>

					<Button Grid.Row="0"
							Grid.Column="4"
							Margin="0,0,0,6"
							Padding="10,4"
							Command="{Binding RemoveCommand}"
							Content="Remove" />

					<TextBox Grid.Row="1"
							 Grid.Column="0"
							 Grid.ColumnSpan="5"
							 Margin="0"
							 Padding="8,4"
							 Height="28"
							 AcceptsReturn="False"
							 TextWrapping="NoWrap"
							 VerticalContentAlignment="Center"
							 HorizontalScrollBarVisibility="Auto"
							 VerticalScrollBarVisibility="Disabled"
							 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
				</Grid>
			</Border>
		</DataTemplate>

	</Window.Resources>

	<Grid Margin="20">
		<TabControl>
			<TabItem Header="Colors">
				<DockPanel>
					<Border DockPanel.Dock="Top"
							Margin="0,0,0,18"
							Padding="18"
							Background="{StaticResource Panel.Default.Background}"
							BorderBrush="{StaticResource Border.Default.Border}"
							BorderThickness="1"
							CornerRadius="10">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Row="0"
										Grid.Column="0"
										Orientation="Horizontal">
								<Button Command="{Binding NewDocumentCommand}" Content="New" />
								<Button Command="{Binding OpenDocumentCommand}" Content="Open" />
								<Button Command="{Binding SaveDocumentCommand}" Content="Save" />
								<Button Command="{Binding SaveDocumentAsCommand}" Content="Save As" />
								<Button Command="{Binding AddCategoryCommand}" Content="Add Category" />
							</StackPanel>

							<TextBlock Grid.Row="0"
									   Grid.Column="1"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
								   Foreground="{StaticResource Text.Selected.Foreground}"
									   Text="{Binding StatusMessage}" />

							<TextBlock Grid.Row="1"
									   Grid.ColumnSpan="2"
									   Margin="0,12,0,0"
									   Text="{Binding CurrentFileDisplay}" />

							<StackPanel Grid.Row="1"
										Grid.Column="1"
										Margin="0,12,0,0"
										Orientation="Horizontal"
										HorizontalAlignment="Right">
								<Button Command="{Binding ExpandAllCategoriesCommand}" Content="Expand All" />
								<Button Command="{Binding CollapseAllCategoriesCommand}" Content="Collapse All" />
							</StackPanel>
						</Grid>
					</Border>

					<Border DockPanel.Dock="Top"
							Margin="0,0,0,18"
							Padding="14"
							Background="{StaticResource Panel.Default.Background}"
							BorderBrush="{StaticResource Border.Default.Border}"
							BorderThickness="1"
							CornerRadius="10"
							Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
						<StackPanel>
							<TextBlock FontWeight="Bold"
									   Foreground="{StaticResource Text.Selected.Foreground}"
									   Text="Validation Issues" />
							<ItemsControl ItemsSource="{Binding ValidationErrors}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<TextBlock Margin="0,4,0,0" Text="{Binding}" />
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Border>

					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding Categories}">
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="{x:Type viewModels:CategoryViewModel}">
									<Expander IsExpanded="{Binding IsExpanded}"
											  HorizontalContentAlignment="Stretch"
										  Background="{StaticResource Panel.Default.Background}">
										<Expander.Header>
											<Grid HorizontalAlignment="Stretch"
												  Width="{Binding RelativeSource={RelativeSource AncestorType=Expander}, Path=ActualWidth}">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="Auto" />
												</Grid.ColumnDefinitions>

												<Grid.Margin>
													<Thickness Left="0" Top="0" Right="13" Bottom="0" />
												</Grid.Margin>

												<TextBox Grid.Column="0"
														 MinWidth="220"
														 Margin="0"
														 Padding="5,0,5,0"
														 VerticalContentAlignment="Center"
														 VerticalAlignment="Center"
														 Height="30"
														 FontSize="14"
														 FontWeight="Bold"
														 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

												<StackPanel Grid.Column="1" Width="239"
														Orientation="Horizontal"
														HorizontalAlignment="Right"
														Margin="10,0,0,0">
													<Button Command="{Binding AddColorCommand}"
															Margin="0,0,0,0"
															Padding="10,0"
															Height="30"
															Content="Add Color" />
													<Button Margin="8,0,0,0"
															Padding="10,0"
															HorizontalContentAlignment="Left"
															Height="30"
															Command="{Binding RemoveCategoryCommand}"
															Content="Remove Category" />
												</StackPanel>
											</Grid>
										</Expander.Header>

										<StackPanel Margin="5,4,14,14">
											<ItemsControl ItemsSource="{Binding StateGroups}" />
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</DockPanel>
			</TabItem>

			<TabItem Header="UI Preview">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<WrapPanel Margin="0" ItemWidth="320">
						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="TextBox" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.TextBox" />
								<TextBox Text="My Text" />
								<TextBox IsEnabled="False" Text="My Text" />
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="Button" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.Button" />
								<Button HorizontalAlignment="Left" Content="Button 1" />
								<Button HorizontalAlignment="Left" IsEnabled="False" Content="Button 1" />
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="Slider" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.Slider" />
								<Slider Minimum="0" Maximum="100" Value="75" />
								<Slider IsEnabled="False" Minimum="0" Maximum="100" Value="75" />
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="ComboBox" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.ComboBox" />
								<ComboBox Template="{StaticResource ComboBoxTemplate}"
										  ItemContainerStyle="{StaticResource ComboPopupItemStyle}"
										  SelectedIndex="0">
									<ComboBox.Resources>
										<SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#8BFF9600" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFC8C8C8" />
										<SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFC8C8C8" />
									</ComboBox.Resources>
									<ComboBoxItem Content="Item 1" />
									<ComboBoxItem Content="Item 2" />
									<ComboBoxItem Content="Item 3" />
								</ComboBox>
								<ComboBox IsEnabled="False"
										  Template="{StaticResource ComboBoxTemplate}"
										  ItemContainerStyle="{StaticResource ComboPopupItemStyle}"
										  SelectedIndex="0">
									<ComboBox.Resources>
										<SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#8BFF9600" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF4C4C4C" />
										<SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFC8C8C8" />
										<SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFC8C8C8" />
									</ComboBox.Resources>
									<ComboBoxItem Content="Item 1" />
									<ComboBoxItem Content="Item 2" />
									<ComboBoxItem Content="Item 3" />
								</ComboBox>
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="CheckBox" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.CheckBox" />
								<CheckBox IsThreeState="True" IsChecked="True" Content="Checked" />
								<CheckBox IsThreeState="True" IsChecked="False" Content="Unchecked" />
								<CheckBox IsThreeState="True" IsChecked="{x:Null}" Content="Indeterminate" />
								<CheckBox IsEnabled="False" IsThreeState="True" IsChecked="True" Content="Checked" />
								<CheckBox IsEnabled="False" IsThreeState="True" IsChecked="False" Content="Unchecked" />
								<CheckBox IsEnabled="False" IsThreeState="True" IsChecked="{x:Null}" Content="Indeterminate" />
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="RadioButton" />
								<TextBlock Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.RadioButton" />
								<RadioButton GroupName="PreviewRadioGroup" IsChecked="True" Content="Option 1" />
								<RadioButton GroupName="PreviewRadioGroup" Content="Option 2" />
								<RadioButton GroupName="PreviewRadioGroupDisabled" IsEnabled="False" IsChecked="True" Content="Option 1" />
								<RadioButton GroupName="PreviewRadioGroupDisabled" IsEnabled="False" Content="Option 2" />
							</StackPanel>
						</Border>

						<Border Margin="0,0,18,18"
								Padding="16"
								Width="300"
								Background="{StaticResource Panel.Default.Background}"
								BorderBrush="{StaticResource Border.Default.Border}"
								BorderThickness="1"
								CornerRadius="10">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="140" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock FontSize="16" FontWeight="SemiBold" Text="CFTreeView" />
								<TextBlock Grid.Row="1" Margin="0,2,0,14" Foreground="{StaticResource Text.Selected.Foreground}" Text="System.Windows.Controls.TreeView" />
								<userControls:CFTreeView Grid.Row="2"
											 IsMultiSelect="True"
											 NodesSource="{Binding PreviewTreeViewNodes}"
											 SelectedValues="{Binding PreviewSelectedTreeViewValues}"
											 SelectedTreeViewItems="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SelectedPreviewTreeViewItems, Mode=OneWayToSource}" />
								<TextBox Grid.Row="3"
										 Margin="0,8,0,0"
										 Height="72"
										 AcceptsReturn="True"
										 IsReadOnly="True"
										 TextWrapping="Wrap"
										 VerticalScrollBarVisibility="Auto"
										 Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SelectedPreviewTreeViewDetails}" />
								<WrapPanel Grid.Row="4"
										   Margin="0,8,0,0">
									<Button Command="{Binding RemovePreviewTreeViewTailCommand}"
											Content="Remove Last 4" />
									<Button Command="{Binding AddPreviewTreeViewTailCommand}"
											Content="Add Last 4" />
									<Button Command="{Binding SelectPreviewPrimaryCommand}"
											Content="Select Primary" />
									<Button Command="{Binding SelectPreviewPrimaryAndAccentCommand}"
											Content="Select Primary + Accent" />
								</WrapPanel>
							</Grid>
						</Border>
					</WrapPanel>
				</ScrollViewer>
			</TabItem>
		</TabControl>
	</Grid>
</Window>
