<Window x:Class="AgenticColorCreator.App.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:viewModels="clr-namespace:AgenticColorCreator.App.ViewModels"
		mc:Ignorable="d"
		Title="Agentic Color Creator"
		Height="900"
		Width="1280"
		MinHeight="720"
		MinWidth="980">
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

		<DataTemplate DataType="{x:Type viewModels:ColorItemViewModel}">
			<Border Margin="0,0,0,12"
					Background="#FF1C2731"
					BorderBrush="{StaticResource BorderBrush}"
					BorderThickness="1"
					CornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<Button Grid.Row="0"
							 Grid.Column="0"
							Width="44"
							Height="26"
							Margin="0,0,8,6"
							Padding="0"
							Background="{Binding PreviewBrush}"
							BorderBrush="#80FFFFFF"
							Command="{Binding OpenColorPickerCommand}">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="1"
										CornerRadius="5" />
							</ControlTemplate>
						</Button.Template>
					</Button>

					<TextBox Grid.Row="0"
							 Grid.Column="1"
							 Margin="0,0,8,6"
							 Padding="5,4"
							 VerticalContentAlignment="Center"
							 Text="{Binding HexValue, UpdateSourceTrigger=PropertyChanged}" />

					<TextBox Grid.Row="0"
							 Grid.Column="2"
							 Margin="0,0,8,6"
							 VerticalContentAlignment="Center"
							 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

					<Button Grid.Row="0"
							Grid.Column="3"
							Margin="0,0,0,6"
							Padding="10,4"
							Command="{Binding RemoveCommand}"
							Content="Remove" />

					<TextBox Grid.Row="1"
							 Grid.Column="0"
							 Grid.ColumnSpan="4"
							 Margin="0"
							 Padding="8,4"
							 Height="28"
							 AcceptsReturn="False"
							 TextWrapping="NoWrap"
							 VerticalContentAlignment="Center"
							 HorizontalScrollBarVisibility="Auto"
							 VerticalScrollBarVisibility="Disabled"
							 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
				</Grid>
			</Border>
		</DataTemplate>
	</Window.Resources>

	<DockPanel Margin="20">
		<Border DockPanel.Dock="Top"
				Margin="0,0,0,18"
				Padding="18"
				Background="#FF15202A"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="10">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Row="0"
							Grid.Column="0"
							Orientation="Horizontal">
					<Button Command="{Binding NewDocumentCommand}" Content="New" />
					<Button Command="{Binding OpenDocumentCommand}" Content="Open" />
					<Button Command="{Binding SaveDocumentCommand}" Content="Save" />
					<Button Command="{Binding SaveDocumentAsCommand}" Content="Save As" />
					<Button Command="{Binding AddCategoryCommand}" Content="Add Category" />
				</StackPanel>

				<TextBlock Grid.Row="0"
						   Grid.Column="1"
						   VerticalAlignment="Center"
						   FontWeight="SemiBold"
						   Foreground="{StaticResource AccentBrush}"
						   Text="{Binding StatusMessage}" />

				<Grid Grid.Row="1"
					  Grid.ColumnSpan="2"
					  Margin="0,12,0,0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<TextBlock Margin="0,0,12,0"
							   VerticalAlignment="Center"
							   FontWeight="SemiBold"
							   Text="Document Title" />
					<TextBox Grid.Column="1"
							 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
				</Grid>

				<TextBlock Grid.Row="2"
						   Grid.ColumnSpan="2"
						   Margin="0,12,0,0"
						   Text="{Binding CurrentFileDisplay}" />
			</Grid>
		</Border>

		<Border DockPanel.Dock="Top"
				Margin="0,0,0,18"
				Padding="14"
				Background="#FF15202A"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="10"
				Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
			<StackPanel>
				<TextBlock FontWeight="Bold"
						   Foreground="#FFFFC285"
						   Text="Validation Issues" />
				<ItemsControl ItemsSource="{Binding ValidationErrors}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<TextBlock Margin="0,4,0,0" Text="{Binding}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>

		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<ItemsControl ItemsSource="{Binding Categories}">
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type viewModels:CategoryViewModel}">
						<Expander IsExpanded="{Binding IsExpanded}"
								  Background="{StaticResource PanelBackgroundBrush}">
							<Expander.Header>
								<!--<Grid Margin="0,0" Background="Red" Height="30">-->
								<Grid>
									<StackPanel Orientation="Horizontal" Margin="0" Background="Transparent">

										<TextBox MinWidth="220" Margin="0" Padding="5,0,5,0"
											VerticalContentAlignment="Center" VerticalAlignment="Center"
											Height="30" FontSize="14" FontWeight="Bold"
											Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

										<Button Grid.Column="0"
												Command="{Binding AddColorCommand}"
												Margin="0" Padding="0"
												Height="30"
												Content="Add Color" />
										<Button Grid.Column="1"
												Margin="0" Padding="0"
												Height="30"
												Command="{Binding RemoveCategoryCommand}"
												Content="Remove Category" />

									</StackPanel>
								</Grid>
								<!--</Grid>-->
							</Expander.Header>

							<StackPanel Margin="5,4,14,14">
								<ItemsControl ItemsSource="{Binding Colors}" />
							</StackPanel>
						</Expander>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</DockPanel>
</Window>
