<Application x:Class="AgenticColorCreator.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF0F141A" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF18212B" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FF304050" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#FFDCE7F3" />
        <SolidColorBrush x:Key="BodyBrush" Color="#FFB7C4D1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF5EB2FF" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF22303D" />
            <Setter Property="Foreground" Value="#FFF1F5F9" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF22303D" />
            <Setter Property="Foreground" Value="#FFF1F5F9" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
    </Application.Resources>
</Application>
